<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- iOS/iPadOS entitlements. Deliberately SEPARATE from Unifyr.entitlements:
	     that file carries macOS App Sandbox keys (Full Disk Access exceptions,
	     Apple-event exceptions for Messages) that have no meaning on iOS and only
	     risk tripping provisioning when installing on a real device. -->

	<!-- iCloud/CloudKit private database (D2) — notes, tags, reminders metadata.
	     Same container as the Mac; this is what makes the two devices one app. -->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.mcgraw.Hyperview</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>

	<!-- Push, for LIVE CloudKit sync: NSPersistentCloudKitContainer receives
	     record-change notifications by silent push, so an edit on another device
	     lands within seconds instead of only on next launch/foreground. Value
	     stays "development"; Xcode's signing swaps it to "production" when
	     archiving for distribution. Pairs with the remote-notification background
	     mode in Info-iOS.plist. -->
	<key>aps-environment</key>
	<string>development</string>

	<!-- Mail ACCOUNT SETTINGS (never the message cache) sync through the iCloud
	     key-value store — see MailAccountSync. -->
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>

	<!-- iCloud Keychain for the mail app passwords and Anthropic API keys
	     (SyncedKeychain). Type them once on the Mac; the phone picks them up. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.mcgraw.Hyperview</string>
	</array>
</dict>
</plist>
