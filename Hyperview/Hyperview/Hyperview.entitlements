<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App Sandbox (D8: Developer ID direct install still runs sandboxed) -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- Outbound network: Anthropic API, Gmail REST, IMAP/SMTP (D9, D10) -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Inbound: local MCP streamable-HTTP server on localhost (§7.2) -->
	<key>com.apple.security.network.server</key>
	<true/>

	<!-- Per-module TCC surfaces (§6); prompts are staggered at runtime, not launch -->
	<key>com.apple.security.personal-information.calendars</key>
	<true/>
	<key>com.apple.security.personal-information.addressbook</key>
	<true/>
	<key>com.apple.security.personal-information.photos-library</key>
	<true/>

	<!-- User-selected file access is driven by the ENABLE_USER_SELECTED_FILES build
	     setting (readonly today); Phase 4 mail attachments revisit it there. -->

	<!-- Notes file links: persist security-scoped bookmarks so a linked file
	     stays openable across app launches. -->
	<key>com.apple.security.files.bookmarks.app-scope</key>
	<true/>

	<!-- Messages module (experimental wrapper): reading ~/Library/Messages/chat.db
	     needs BOTH this sandbox exception (fine for Developer ID direct install;
	     not App Store) AND user-granted Full Disk Access (TCC). Read-only. -->
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<string>/Library/Messages/</string>
	</array>
	<!-- Sending: automate Messages.app via Apple events (TCC prompt on first
	     send). BOTH keys are required: automation.apple-events satisfies the
	     hardened runtime, but the App Sandbox separately blocks events to any
	     app not listed in a temporary exception — without it the send fails
	     with a misleading -600 "Application isn't running". -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
	<key>com.apple.security.temporary-exception.apple-events</key>
	<array>
		<string>com.apple.MobileSMS</string>
	</array>

	<!-- iCloud/CloudKit private database (D2). SwiftData binds to this container
	     via cloudKitDatabase: .automatic. The production schema is promoted
	     exactly once at the end of Phase 2 (§9 phase-gate); development runs
	     against the CloudKit development environment until then. -->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.mcgraw.Hyperview</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>
</dict>
</plist>
